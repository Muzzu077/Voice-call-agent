# LLM Configuration
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Whisper STT (Phase 2)
WHISPER_MODEL_SIZE=base

# TTS (Phase 3)
TTS_ENGINE=kokoro

# Memory
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/voice_agent.db

# Audio
VAD_THRESHOLD=0.5
AUDIO_SAMPLE_RATE=16000

# Twilio (Phase 4)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Server
HOST=0.0.0.0
PORT=8000
