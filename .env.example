# ── AI Voice + Desktop Agent Platform ─────────────
# Copy this to .env and fill in your values

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agent:agent_secret_2026@localhost:5432/voiceagent

# ── Auth ─────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── LLM ──────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB Vector Store ────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Whisper STT ──────────────────────────────────
WHISPER_MODEL_SIZE=base.en

# ── TTS ──────────────────────────────────────────
TTS_ENGINE=kokoro

# ── Audio ────────────────────────────────────────
VAD_THRESHOLD=0.5
AUDIO_SAMPLE_RATE=16000

# ── Twilio ───────────────────────────────────────
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_CALLBACK_NUMBER=+911234567890

# ── Server ───────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
